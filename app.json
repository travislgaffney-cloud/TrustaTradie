{
  "expo": {
    "name": "Trust-a-Tradie",
    "slug": "trust-a-tradie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trustatradie",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trustatradie.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Trust-a-Tradie uses your location to show nearby jobs and tradies.",
        "NSLocationAlwaysUsageDescription": "Trust-a-Tradie uses your location to notify tradies of nearby jobs.",
        "NSCameraUsageDescription": "Used to take photos for job posts and portfolio images.",
        "NSPhotoLibraryUsageDescription": "Used to upload photos for jobs, portfolio, and documents.",
        "NSMicrophoneUsageDescription": "Required for camera access."
      },
      "config": {
        "googleMapsApiKey": ""
      }
    },
    "android": {
      "package": "com.trustatradie.app",
      "adaptiveIcon": {
        "backgroundColor": "#F97316",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#0f172a"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Trust-a-Tradie uses your location to show nearby jobs and tradies."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Used to take photos for job posts and portfolio images."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to upload photos for jobs, portfolio, and documents."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#F97316",
          "sounds": []
        }
      ],
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
